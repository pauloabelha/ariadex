{
  "manifest_version": 3,
  "name": "Ariadex",
  "version": "0.1",
  "description": "Injects an Explore button into X tweets to bootstrap conversation exploration.",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["https://x.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
