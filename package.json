{
  "name": "ariadex",
  "version": "0.1.0",
  "private": true,
  "description": "Ariadex Chrome extension MVP",
  "engines": {
    "node": ">=18 <23",
    "npm": ">=9"
  },
  "packageManager": "npm@10",
  "scripts": {
    "test": "node --test tests/*.js",
    "sync:env": "node scripts/sync_env_to_generated_config.js",
    "env:dev": "node scripts/set_runtime_env.js --env=dev",
    "env:prod": "node scripts/set_runtime_env.js --env=prod",
    "start:graph-cache": "node server/graph_cache_server.js",
    "dev:cache": "node scripts/dev_with_graph_cache.js",
    "benchmark:snapshot": "node scripts/benchmark_snapshot_pipeline.js"
  },
  "devDependencies": {
    "jsdom": "26.0.0"
  }
}
